# Port the HTTP + WebSocket server listens on.
# Railway / Render inject their own PORT automatically; keep 3000 for local dev.
PORT=3000

# Optional shared secret for GC7 Login. Leave empty during bring-up
# (login is accepted without enforcement until we wire this up).
GANTNER_ACCESS_TOKEN=

# Heartbeat interval (seconds) advertised back to the controller (HBI). Optional.
HEARTBEAT_INTERVAL=30

# Subscribe to controller events (IO.*/FIU.*/Addon.*) on connect. Default true.
GANTNER_REGISTER_EVENTS=true

# LIVE DECISION SWITCH. false (default) = a scan is still validated against Clap
# House and the decision is recorded (shadow mode), but NO door is opened. true =
# the backend transmits IO.SetRelayState to OPEN the gate on a Clap-House-GRANTED
# scan. Flip to true to go live end-to-end.
GANTNER_SEND_UNLOCK=false

# --- Clap House (source of truth for access) ---------------------------------
# Endpoint the backend POSTs each scanned QR to for the grant/deny decision.
CLAPHOUSE_VALIDATE_URL=https://claphouse.co/api/access/validate

# Shared gate key, sent as the `x-gate-key` header. Leave EMPTY until you set the
# same value here AND in Clap House's Vercel env at the same time (Clap House
# auto-enforces it the moment it is set). 32+ random chars.
GATE_API_KEY=

# Timeout (ms) for the Clap House validate call. On timeout/error we FAIL CLOSED.
CLAPHOUSE_TIMEOUT_MS=5000

# Admin secret for the destructive relay-control endpoints (/relay/pulse,
# /relay/close-all). EMPTY (default) disables them entirely (403). To use them in
# production, set a strong value and send it as the `x-admin-key` header.
ADMIN_API_KEY=

# Relay to pulse for a granted scan on a not-yet-identified controller. All live
# gates here use relay 2; leave at 2 unless the site wiring differs.
GANTNER_FALLBACK_RELAY=2

# Log full raw/parsed scan frames (which contain the live token). false (default)
# redacts the token before logging/capture. Turn on ONLY for local debugging.
GANTNER_LOG_RAW_FRAMES=false
